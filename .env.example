# Leaderboard (GridWatchGamesDB on Supabase).
# Copy to .env.local for local dev, and set the same two vars in the
# Cloudflare Pages project (Settings → Environment variables) for production.
# Both values are publishable: the leaderboard is protected by RLS plus
# server-side replay validation, not by hiding these.
#
# If unset, the game runs normally with the leaderboard disabled.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key
