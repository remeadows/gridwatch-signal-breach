{
  "name": "gridwatch-signal-breach",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:validator": "esbuild src/sim/index.ts --bundle --format=esm --platform=neutral --target=es2022 --legal-comments=none --outfile=supabase/functions/submit-gridwatch-score/sim.bundle.js",
    "balance:report": "node scripts/run-typescript.mjs scripts/balance-report.ts",
    "balance:search": "node scripts/run-typescript.mjs scripts/search-balance.ts",
    "typecheck:tools": "tsc -p tsconfig.tools.json",
    "verify:content": "node scripts/run-typescript.mjs scripts/verify-content.ts",
    "verify:latency-trap": "node scripts/run-typescript.mjs scripts/verify-latency-trap.ts",
    "verify:progress": "node scripts/run-typescript.mjs scripts/verify-progress.ts",
    "verify:replays": "node scripts/run-typescript.mjs scripts/verify-replays.ts",
    "verify:rusher": "node scripts/run-typescript.mjs scripts/verify-rusher.ts",
    "verify:assets": "node scripts/verify-assets.mjs"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5"
  }
}
